    // ==========================================
    // TESTS: GET /api/v1/inventario/analisis-abc/sucursal/{sucursalId}/resumen
    // ==========================================

    @Test
    @DisplayName("GET /sucursal/{id}/resumen - Debe obtener resumen estadístico exitosamente")
    void testObtenerResumen_Exitoso() throws Exception {
        // Given
        AnalisisABCResumenDTO resumenDTO = new AnalisisABCResumenDTO();
        resumenDTO.setSucursalId(1);
        resumenDTO.setNombreSucursal("Sucursal Centro");
        resumenDTO.setFechaAnalisis(LocalDate.of(2026, 4, 1));
        resumenDTO.setPeriodoInicio(LocalDate.of(2026, 1, 1));
        resumenDTO.setPeriodoFin(LocalDate.of(2026, 3, 31));
        resumenDTO.setTotalProductos(3);
        resumenDTO.setValorTotalVentas(BigDecimal.valueOf(17650.00));
        
        AnalisisABCResumenDTO.ResumenClasificacion resumenA = new AnalisisABCResumenDTO.ResumenClasificacion();
        resumenA.setCantidadProductos(1);
        resumenA.setPorcentajeProductos(BigDecimal.valueOf(33.33));
        resumenA.setValorVentas(BigDecimal.valueOf(15000.00));
        resumenA.setPorcentajeValor(BigDecimal.valueOf(85.00));
        resumenDTO.setClasificacionA(resumenA);

        AnalisisABCResumenDTO.ResumenClasificacion resumenB = new AnalisisABCResumenDTO.ResumenClasificacion();
        resumenB.setCantidadProductos(1);
        resumenB.setValorVentas(BigDecimal.valueOf(2400.00));
        resumenB.setPorcentajeValor(BigDecimal.valueOf(13.60));
        resumenDTO.setClasificacionB(resumenB);

        AnalisisABCResumenDTO.ResumenClasificacion resumenC = new AnalisisABCResumenDTO.ResumenClasificacion();
        resumenC.setCantidadProductos(1);
        resumenC.setValorVentas(BigDecimal.valueOf(250.00));
        resumenC.setPorcentajeValor(BigDecimal.valueOf(1.40));
        resumenDTO.setClasificacionC(resumenC);

        resumenDTO.setProductosClaseA(Arrays.asList(responseDTO1));

        when(analisisService.obtenerResumen(eq(1)))
            .thenReturn(resumenDTO);

        // When & Then
        mockMvc.perform(get("/api/v1/inventario/analisis-abc/sucursal/1/resumen"))
                .andExpect(status().isOk())
                .andExpect(jsonPath("$.totalProductos", is(3)))
                .andExpect(jsonPath("$.valorTotalVentas", is(17650.00)))
                .andExpect(jsonPath("$.clasificacionA.cantidadProductos", is(1)))
                .andExpect(jsonPath("$.clasificacionA.porcentajeValor", is(85.00)))
                .andExpect(jsonPath("$.clasificacionB.cantidadProductos", is(1)))
                .andExpect(jsonPath("$.clasificacionC.cantidadProductos", is(1)))
                .andExpect(jsonPath("$.productosClaseA", hasSize(1)))
                .andExpect(jsonPath("$.productosClaseA[0].clasificacion", is("A")));

        verify(analisisService, times(1)).obtenerResumen(eq(1));
    }

    @Test
    @DisplayName("GET /sucursal/{id}/resumen - Debe retornar error cuando no hay datos")
    void testObtenerResumen_SinDatos() throws Exception {
        // Given
        when(analisisService.obtenerResumen(eq(1)))
            .thenThrow(new BusinessException("No se encontró análisis para la sucursal especificada"));

        // When & Then
        mockMvc.perform(get("/api/v1/inventario/analisis-abc/sucursal/1/resumen"))
                .andExpect(status().isBadRequest())
                .andExpect(jsonPath("$.mensaje", containsString("No se encontró análisis")));

        verify(analisisService, times(1)).obtenerResumen(eq(1));
    }
}
